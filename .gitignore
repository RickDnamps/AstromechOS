# ============================================================
# R2-D2 Project — .gitignore
# ============================================================

# Config locale — NE JAMAIS commiter (contient WiFi + GitHub URL)
master/config/local.cfg

# Mémoire locale Claude Code
.claude/

# Code de référence tiers (r2_control by dpoulson)
others/


# Dépendances vendored (générées par vendor_deps.sh)
slave/vendor/

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# Logs
*.log

# Dossiers de debug générés automatiquement
debug/

# Environnements virtuels
.env
.envrc
.venv
env/
venv/
ENV/

# Tests / coverage
.coverage
.coverage.*
.pytest_cache/
htmlcov/
.tox/
.nox/

# Type checkers
.mypy_cache/
.dmypy.json
.pytype/
.pyre/
.ruff_cache/

# Outils divers
.pypirc
__pypackages__/
.pdm-python
.pdm-build/
.pixi
celerybeat-schedule
celerybeat.pid
*.sage.py

# IDE
.idea/
.vscode/
.spyderproject
.ropeproject

# Jupyter
.ipynb_checkpoints
profile_default/
ipython_config.py

# Docs
/site
docs/_build/
